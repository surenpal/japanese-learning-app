[
  {
    "pattern": "〜は〜です",
    "meaning": "A is B",
    "usage": {
      "a": "Topic marker は",
      "b": "Used to state that A equals or is B"
    },
    "example1": "わたしは学生です。",
    "exampleTrans1": "I am a student.",
    "example2": "これは本です。",
    "exampleTrans2": "This is a book.",
    "example3": "田中さんは先生です。",
    "exampleTrans3": "Mr. Tanaka is a teacher."
  },
  {
    "pattern": "〜は〜ではありません",
    "meaning": "A is not B",
    "usage": {
      "a": "Negative form of です",
      "b": "Used to deny a statement"
    },
    "example1": "わたしは先生ではありません。",
    "exampleTrans1": "I am not a teacher.",
    "example2": "これはペンではありません。",
    "exampleTrans2": "This is not a pen.",
    "example3": "彼は学生ではありません。",
    "exampleTrans3": "He is not a student."
  },
  {
    "pattern": "〜は〜ですか",
    "meaning": "Is A B?",
    "usage": {
      "a": "Add か at the end",
      "b": "Forms a yes/no question"
    },
    "example1": "あなたは学生ですか。",
    "exampleTrans1": "Are you a student?",
    "example2": "これは本ですか。",
    "exampleTrans2": "Is this a book?",
