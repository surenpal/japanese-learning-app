    "exampleTrans3": "Is Mr. Tanaka a teacher?"
  },
  {
    "pattern": "〜も",
    "meaning": "also / too",
    "usage": {
      "a": "Replaces は, が, or を",
      "b": "Indicates inclusion"
    },
    "example1": "わたしも学生です。",
    "exampleTrans1": "I am also a student.",
    "example2": "彼も来ます。",
    "exampleTrans2": "He will come too.",
    "example3": "これもください。",
    "exampleTrans3": "Please give me this too."
  },
  {
    "pattern": "〜の",
